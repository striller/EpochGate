# EpochGate Configuration
# Copy this file to .env and adjust values as needed

# Address to listen on
LISTEN_PORT=:8080

# Nexus repository proxy URL
NEXUS_URL=http://localhost:8081/repository/npm-proxy/

# Upstream npm registry to check package metadata
NPM_REGISTRY=https://registry.npmjs.org/

# Minimum package age in days before allowing
MIN_AGE_DAYS=7
